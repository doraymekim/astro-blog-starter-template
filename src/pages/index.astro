			<!-- CLIENT SIDE SCRIPT -->
		<script>
			// @ts-nocheck
			// FILM REEL INTERACTION FIX
			const video = document.getElementById('filmReelVideo');
			const overlay = document.getElementById('videoOverlay');
			const videoContainer = document.getElementById('videoContainer');

			if (video instanceof HTMLVideoElement && overlay instanceof HTMLElement) {
				const handlePlaybackToggle = (e) => {
					e.preventDefault();
					if (video.paused || video.ended) {
						video.play().then(() => {
							overlay.classList.add('hidden');
						}).catch((err) => console.log('Playback requested standard check:', err));
					} else {
						video.pause();
						overlay.classList.remove('hidden');
					}
				};

				overlay.addEventListener('click', handlePlaybackToggle);
				video.addEventListener('play', () => overlay.classList.add('hidden'));
				video.addEventListener('pause', () => overlay.classList.remove('hidden'));
			}

			// YOUTUBE VIDEO GAME REEL OVERLAY STATE ENGINE
			const ytOverlay = document.getElementById('ytVideoOverlay');
			const ytFrame = document.getElementById('vgPlayerFrame');
			let ytPlayer;

			const hideYTOverlay = () => {
				if (ytOverlay instanceof HTMLElement) ytOverlay.classList.add('hidden');
			};

			const showYTOverlay = () => {
				if (ytOverlay instanceof HTMLElement) ytOverlay.classList.remove('hidden');
			};

			const onYTPlayerStateChange = (event) => {
				if (event.data === YT.PlayerState.PLAYING) {
					hideYTOverlay();
				} else if (event.data === YT.PlayerState.PAUSED || event.data === YT.PlayerState.ENDED) {
					showYTOverlay();
				}
			};

			window.onYouTubeIframeAPIReady = () => {
				if (typeof YT !== 'undefined' && YT.Player && ytFrame instanceof HTMLIFrameElement) {
					ytPlayer = new YT.Player('vgPlayerFrame', {
						events: {
							onStateChange: onYTPlayerStateChange,
						},
					});
				}
			};

			if (ytOverlay instanceof HTMLElement) {
				ytOverlay.addEventListener('click', (e) => {
					e.preventDefault();
					hideYTOverlay();
					if (ytPlayer && typeof ytPlayer.playVideo === 'function') {
						ytPlayer.playVideo();
					} else if (ytFrame instanceof HTMLIFrameElement) {
						ytFrame.contentWindow.postMessage('{"event":"command","func":"playVideo","args":""}', '*');
					}
				});
			}

			if (!window.YT) {
				const tag = document.createElement('script');
				tag.src = 'https://www.youtube.com/iframe_api';
				document.body.appendChild(tag);
			}
		</script>
