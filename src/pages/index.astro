---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		
		<!-- 1. LOAD FONT AWESOME FOR THE ICONS -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

		<style>
			/* Import the Paperlogy font family */
			@import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css');
			@font-face {
				font-family: 'Paperlogy';
				src: url('https://fastly.jsdelivr.net/gh/projectnoonnu/2411-3@1.0/Paperlogy-Thin.woff2') format('woff2');
				font-weight: 300;
			}
			@font-face {
				font-family: 'Paperlogy';
				src: url('https://fastly.jsdelivr.net/gh/projectnoonnu/2411-3@1.0/Paperlogy-Medium.woff2') format('woff2');
				font-weight: 500;
			}

			html, body {
				margin: 0;
				padding: 0;
				width: 100%;
				height: 100%;
				overflow-x: hidden;
				overflow-y: auto;
				scroll-behavior: smooth;
				font-family: 'Paperlogy', 'Pretendard', sans-serif;
				background-color: #000000;
			}
			.hero-container {
				position: relative;
				width: 100%;
				height: 100vh;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				background-image: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2)), url('/Ray Conduct.JPG');
				background-size: cover;
				background-position: center;
				background-repeat: no-repeat;
			}
			.logo-wrapper {
				position: absolute;
				top: 8vh;
				left: 50%;
				transform: translateX(-50%);
				z-index: 10;
			}
			.site-logo {
				width: 110px; 
				height: auto;
				object-fit: contain;
				filter: drop-shadow(0px 4px 12px rgba(0, 0, 0, 0.5));
			}
			.text-overlay {
				background: rgba(0, 0, 0, 0.25);
				padding: 2.5rem 4rem;
				border-radius: 12px;
				backdrop-filter: blur(8px);
				-webkit-backdrop-filter: blur(8px);
				border: 1px solid rgba(255, 255, 255, 0.1);
				text-align: center;
				max-width: 80%;
				margin-top: 10vh;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 1.5rem;
			}
			.site-title {
				color: white;
				font-size: 3.5rem;
				font-weight: 300;
				text-transform: uppercase;
				letter-spacing: 6px;
				margin: 0;
				padding: 0;
				text-shadow: 1px 1px 5px rgba(0, 0, 0, 0.3);
			}

			/* 2. STYLE THE SOCIAL ICONS CONTAINER */
			.social-icons {
				display: flex;
				gap: 1.4rem; 
				margin-top: 0.5rem;
			}
			.social-link {
				color: rgba(255, 255, 255, 0.7);
				font-size: 2.1rem; 
				transition: color 0.3s ease, transform 0.3s ease;
				text-decoration: none;
			}
			.social-link:hover {
				color: #ffffff;
				transform: scale(1.1); 
			}

			/* 3. STYLE THE SCROLLABLE SECOND PAGE (VIDEO PLACEMENT) */
			.video-section {
				width: 100%;
				height: 100vh;
				display: flex;
				justify-content: center;
				align-items: center;
				background: #0d0d0d;
				padding: 20px;
				box-sizing: border-box;
			}
			.video-wrapper {
				position: relative; 
				width: 100%;
				max-width: 1250px;
				aspect-ratio: 16 / 9;
				box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.7);
				border-radius: 8px;
				overflow: hidden;
				border: 1px solid rgba(255, 255, 255, 0.05);
			}
			.main-video {
				width: 100%;
				height: 100%;
				display: block;
				object-fit: cover;
				background: #000000;
			}
			.video-blur-overlay {
				position: absolute;
				top: 50%;
				left: 50%;
				transform: translate(-50%, -50%);
				background: rgba(0, 0, 0, 0.35); 
				padding: 2rem 4rem;
				border-radius: 12px;
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
				border: 1px solid rgba(255, 255, 255, 0.1);
				text-align: center;
				pointer-events: none; 
				z-index: 5;
				transition: opacity 0.4s ease, visibility 0.4s ease;
			}
			.video-blur-overlay.hidden {
				opacity: 0;
				visibility: hidden;
			}
			.video-subtitle {
				color: white;
				font-family: 'Paperlogy', sans-serif;
				font-size: 3.15rem; 
				font-weight: 300;
				text-transform: uppercase;
				letter-spacing: 6px;
				margin: 0;
				padding: 0;
				text-shadow: 1px 1px 5px rgba(0, 0, 0, 0.4);
				white-space: nowrap;
			}

			/* 4. BANNER IMAGE HERO */
			.carousel-header-bg {
				width: 100%;
				height: 36vh; 
				display: flex;
				justify-content: center;
				align-items: center;
				background-image: linear-gradient(rgba(0, 0, 0, 0.1), rgba(5, 5, 5, 1)), url('/ray orch.jpeg');
				background-size: cover;
				background-position: center 80%; 
				background-repeat: no-repeat;
				box-sizing: border-box;
			}
			.carousel-title-box {
				background: rgba(0, 0, 0, 0.4);
				padding: 1.2rem 3rem;
				border-radius: 8px;
				backdrop-filter: blur(6px);
				-webkit-backdrop-filter: blur(6px);
				border: 1px solid rgba(255, 255, 255, 0.1);
				text-align: center;
				margin-top: 2vh;
			}
			.carousel-section-title {
				color: white;
				font-family: 'Paperlogy', sans-serif;
				font-size: 2.5rem;
				font-weight: 300;
				text-transform: uppercase;
				letter-spacing: 5px;
				margin: 0;
				text-shadow: 0px 4px 12px rgba(0, 0, 0, 0.9);
			}

			/* 5. STYLE THE LOWER CAROUSEL BLOCK */
			.carousel-section {
				width: 100%;
				background: #050505; 
				box-sizing: border-box;
				padding: 10px 0 60px 0;
				position: relative;
			}
			.carousel-container {
				width: 100%;
				overflow: hidden;
				position: relative;
				padding: 20px 0;
			}
			
			/* Soft edge gradients covering background items */
			.carousel-container::before,
			.carousel-container::after {
				background: linear-gradient(to right, #050505 0%, rgba(5, 5, 5, 0) 100%);
				content: "";
				height: 100%;
				position: absolute;
				width: 150px;
				z-index: 2;
				top: 0;
				pointer-events: none;
			}
			.carousel-container::before { left: 0; }
			.carousel-container::after { right: 0; transform: rotateZ(180deg); }

			.carousel-track {
				display: flex;
				width: max-content;
				gap: 2.5rem;
				animation: scroll 110s linear infinite; 
				will-change: transform;
			}
			.carousel-container:hover .carousel-track {
				animation-play-state: paused;
			}
			
			/* POSTER CARD LOGIC WITH INTEGRATED MEMO STRIP */
			.poster-card {
				width: 240px;
				display: flex;
				flex-direction: column;
				position: relative;
				border-radius: 6px;
				overflow: hidden;
				box-shadow: 0 8px 25px rgba(0, 0, 0, 0.7);
				border: 1px solid rgba(255, 255, 255, 0.08);
				transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.4s ease, filter 0.4s ease;
				cursor: pointer;
				background-color: #111111;
				text-decoration: none; /* Keeps text decoration clean */
			}
			.image-wrapper {
				width: 100%;
				aspect-ratio: 2 / 3;
				overflow: hidden;
			}
			.poster-card img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			
			/* CLEAN OVERLAY CARD POSITIONING */
			.poster-memo {
				background: rgba(13, 13, 13, 0.9);
				color: rgba(255, 255, 255, 0.85);
				font-size: 0.72rem;
				font-weight: 300;
				text-align: center;
				padding: 0.6rem 0.4rem;
				border-top: 1px solid rgba(255, 255, 255, 0.05);
				letter-spacing: 0.5px;
				line-height: 1.3;
				white-space: normal;
				word-break: keep-all;
			}

			.poster-card:hover {
				transform: scale(1.08);
				box-shadow: 0 15px 35px rgba(0, 0, 0, 0.9), 0 0 15px rgba(255, 255, 255, 0.2);
				z-index: 10;
			}
			.carousel-track:hover .poster-card:not(:hover) {
				filter: brightness(0.4) contrast(0.85);
			}

			/* NAVIGATION ARROWS FOR MANUAL SCROLLING */
			.carousel-arrow {
				position: absolute;
				top: 50%;
				transform: translateY(-50%);
				background: rgba(0, 0, 0, 0.45);
				border: 1px solid rgba(255, 255, 255, 0.15);
				color: rgba(255, 255, 255, 0.7);
				width: 50px;
				height: 50px;
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 1.25rem;
				cursor: pointer;
				z-index: 15;
				transition: all 0.3s ease;
				backdrop-filter: blur(4px);
				-webkit-backdrop-filter: blur(4px);
			}
			.carousel-arrow:hover {
				background: rgba(255, 255, 255, 0.9);
				color: #000000;
				border-color: #ffffff;
				box-shadow: 0 0 15px rgba(255, 255, 255, 0.3);
			}
			.carousel-arrow.left { left: 25px; }
			.carousel-arrow.right { right: 25px; }

			@keyframes scroll {
				0% { transform: translateX(0); }
				100% { transform: translateX(calc(-50% - 1.25rem)); } 
			}

			@media (max-width: 768px) {
				.logo-wrapper { top: 6vh; }
				.site-logo { width: 80px; }
				.text-overlay { padding: 1.5rem 2rem; margin-top: 8vh; }
				.site-title { font-size: 2.2rem; letter-spacing: 4px; }
				.social-link { font-size: 1.7rem; }
				.video-section { height: auto; padding: 60px 20px; }
				.video-blur-overlay { padding: 1rem 2rem; }
				.video-subtitle { font-size: 1.98rem; letter-spacing: 4px; }
				
				.carousel-header-bg { height: 24vh; background-position: center 75%; }
				.carousel-section { padding-bottom: 40px; }
				.carousel-section-title { font-size: 1.8rem; letter-spacing: 3px; }
				.carousel-title-box { padding: 0.8rem 1.5rem; }
				.poster-card { width: 160px; }
				.poster-memo { font-size: 0.6rem; padding: 0.4rem 0.2rem; }
				.carousel-arrow { width: 40px; height: 40px; font-size: 1rem; }
				.carousel-arrow.left { left: 10px; }
				.carousel-arrow.right { right: 10px; }
			}
		</style>
	</head>
