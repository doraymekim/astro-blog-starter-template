---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		
		<!-- 1. LOAD FONT AWESOME FOR THE ICONS -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

		<style>
			/* Import the Paperlogy font family */
			@import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css');
			@font-face {
				font-family: 'Paperlogy';
				src: url('https://fastly.jsdelivr.net/gh/projectnoonnu/2411-3@1.0/Paperlogy-Thin.woff2') format('woff2');
				font-weight: 300;
			}
			@font-face {
				font-family: 'Paperlogy';
				src: url('https://fastly.jsdelivr.net/gh/projectnoonnu/2411-3@1.0/Paperlogy-Medium.woff2') format('woff2');
				font-weight: 500;
			}

			html, body {
				margin: 0;
				padding: 0;
				width: 100%;
				height: 100%;
				overflow-x: hidden;
				overflow-y: auto;
				scroll-behavior: smooth;
				font-family: 'Paperlogy', 'Pretendard', sans-serif;
				background-color: #000000;
			}
			.hero-container {
				position: relative;
				width: 100%;
				height: 100vh;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				background-image: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2)), url('/Ray Conduct.JPG');
				background-size: cover;
				background-position: center;
				background-repeat: no-repeat;
			}
			.logo-wrapper {
				position: absolute;
				top: 8vh;
				left: 50%;
				transform: translateX(-50%);
				z-index: 10;
			}
			.site-logo {
				width: 110px; 
				height: auto;
				object-fit: contain;
				filter: drop-shadow(0px 4px 12px rgba(0, 0, 0, 0.5));
			}
			.text-overlay {
				background: rgba(0, 0, 0, 0.25);
				padding: 2.5rem 4rem;
				border-radius: 12px;
				backdrop-filter: blur(8px);
				-webkit-backdrop-filter: blur(8px);
				border: 1px solid rgba(255, 255, 255, 0.1);
				text-align: center;
				max-width: 80%;
				margin-top: 10vh;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 1.5rem;
			}
			.site-title {
				color: white;
				font-size: 3.5rem;
				font-weight: 300;
				text-transform: uppercase;
				letter-spacing: 6px;
				margin: 0;
				padding: 0;
				text-shadow: 1px 1px 5px rgba(0, 0, 0, 0.3);
			}

			/* 2. STYLE THE SOCIAL ICONS CONTAINER */
			.social-icons {
				display: flex;
				gap: 1.4rem; 
				margin-top: 0.5rem;
			}
			.social-link {
				color: rgba(255, 255, 255, 0.7);
				font-size: 2.1rem; 
				transition: color 0.3s ease, transform 0.3s ease;
				text-decoration: none;
			}
			.social-link:hover {
				color: #ffffff;
				transform: scale(1.1); 
			}

			/* 3. STYLE THE SCROLLABLE SECOND PAGE (VIDEO PLACEMENT) */
			.video-section {
				width: 100%;
				height: 100vh;
				display: flex;
				justify-content: center;
				align-items: center;
				background: #0d0d0d;
				padding: 20px;
				box-sizing: border-box;
			}
			.video-wrapper {
				width: 100%;
				/* BUMPED SIZE UP BY 25% (From 1000px max-width to 1250px) */
				max-width: 1250px;
				aspect-ratio: 16 / 9;
				box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.7);
				border-radius: 8px;
				overflow: hidden;
				border: 1px solid rgba(255, 255, 255, 0.05);
			}
			.main-video {
				width: 100%;
				height: 100%;
				display: block;
				object-fit: cover;
				background: #000000;
			}

			@media (max-width: 768px) {
				.logo-wrapper {
					top: 6vh;
				}
				.site-logo {
					width: 80px; 
				}
				.text-overlay {
					padding: 1.5rem 2rem;
					margin-top: 8vh;
				}
				.site-title {
					font-size: 2.2rem;
					letter-spacing: 4px;
				}
				.social-link {
					font-size: 1.7rem; 
				}
				.video-section {
					height: auto;
					padding: 60px 20px;
				}
			}
		</style>
	</head>
	<body>
		<!-- FIRST PAGE: LANDING HERO -->
		<main class="hero-container">
			<div class="logo-wrapper">
				<img src="/iTunesArtwork@2x.png" alt="Superrray Productions Logo" class="site-logo" />
			</div>
			
			<div class="text-overlay">
				<h1 class="site-title">Superrray Productions</h1>
				<div class="social-icons">
					<a href="https://www.imdb.com/name/nm8105113/" target="_blank" class="social-link" aria-label="IMDb"><i class="fa-brands fa-imdb"></i></a>
					<a href="https://www.instagram.com/doraymekim/" target="_blank" class="social-link" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
					<a href="https://music.apple.com/us/artist/ray-d-kim/780192649" target="_blank" class="social-link" aria-label="Apple Music"><i class="fa-brands fa-apple"></i></a>
					<a href="https://open.spotify.com/artist/1JHFQv8E0HG7mmKpuftPLB?trackId=6DDJvEGIgYBg4oO6kdh1AF" target="_blank" class="social-link" aria-label="Spotify"><i class="fa-brands fa-spotify"></i></a>
				</div>
			</div>
		</main>

		<!-- SECOND PAGE: SCROLLABLE VIDEO PLACEMENT -->
		<section class="video-section">
			<div class="video-wrapper">
				<video controls preload="metadata" class="main-video" poster="/Ray Conduct.JPG">
					<!-- Spaces are converted to %20 so browsers handle the exact filename correctly -->
					<source src="/Film%20Reel%20250705%2024%20rf23.mp4" type="video/mp4" />
					Your browser does not support the video tag.
				</video>
			</div>
		</section>
	</body>
</html>
