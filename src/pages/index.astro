---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Updating the browser tab name variables here
const SITE_TITLE = "Superrray Productions";
const SITE_DESCRIPTION = "Composer & Score Supervisor Portfolio";
---

<!doctype html>
<html lang="en">
	<head>
		<!-- Pass the updated site title directly to your head component -->
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		
		<!-- FAVICON SOURCE ENFORCED -->
		<link rel="icon" type="image/png" href="/iTunesArtwork@2x.png?v=2" />
		<link rel="apple-touch-icon" href="/iTunesArtwork@2x.png?v=2" />
		
		<!-- LOAD FONT AWESOME FOR ICONS -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

		<style>
			@import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css');
			@font-face {
				font-family: 'Paperlogy';
				src: url('https://fastly.jsdelivr.net/gh/projectnoonnu/2411-3@1.0/Paperlogy-Thin.woff2') format('woff2');
				font-weight: 300;
			}
			@font-face {
				font-family: 'Paperlogy';
				src: url('https://fastly.jsdelivr.net/gh/projectnoonnu/2411-3@1.0/Paperlogy-Medium.woff2') format('woff2');
				font-weight: 500;
			}

			html, body {
				margin: 0;
				padding: 0;
				width: 100%;
				height: 100%;
				overflow-x: hidden;
				overflow-y: auto;
				scroll-behavior: smooth;
				font-family: 'Paperlogy', 'Pretendard', sans-serif;
				background-color: #000000;
			}
			
			/* NAVBAR LOGO POSITIONING */
			.site-navbar {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				padding: 1.5rem 3rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
				z-index: 100;
				background: linear-gradient(to bottom, rgba(0,0,0,0.7), rgba(0,0,0,0));
			}
			.navbar-brand {
				color: white;
				font-size: 1.3rem;
				font-weight: 300;
				text-transform: uppercase;
				letter-spacing: 2px;
				text-decoration: none;
			}
			.nav-left {
				display: flex;
				align-items: center;
			}
			
			/* subtle floating animation for top-left nav items */
			.nav-left {
				animation: navFloat 6s ease-in-out infinite alternate;
			}
			@keyframes navFloat {
				from { transform: translateY(0); }
				to { transform: translateY(-4px); }
			}
			.nav-link:hover { transform: translateY(-6px) scale(1.02); }
			.nav-link {
				color: white;
				font-size: 1rem;
				text-decoration: none;
				margin-right: 1rem;
				padding: 0.35rem 0.65rem;
				border-radius: 6px;
				transition: background 180ms ease;
			}
			.nav-link:hover { background: rgba(255,255,255,0.06); }

			/* HERO LAYER BACKGROUND */
			.hero-container {
				position: relative;
				width: 100%;
				height: 100vh;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				background-image: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2)), url('/Ray Conduct.JPG');
				background-size: cover;
				background-position: center;
				background-repeat: no-repeat;
			}
			.logo-wrapper { display: none; }
			.site-logo {
				width: auto;
				max-height: 44px;
				height: auto;
				object-fit: contain;
				filter: drop-shadow(0px 4px 12px rgba(0, 0, 0, 0.5));
			}
			.nav-right { display: flex; align-items: center; gap: 0.75rem; }
			
			/* HERO TEXT OVERLAY & FROSTED GLASS ADJUSTMENT */
			.text-overlay {
				background: rgba(0, 0, 0, 0.25);
				padding: 2.5rem 4rem;
				border-radius: 13.2px; 
				backdrop-filter: blur(8px);
				-webkit-backdrop-filter: blur(8px);
				border: 1px solid rgba(255, 255, 255, 0.1);
				text-align: center;
				max-width: 80%;
				margin-top: 10vh;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 1.5rem;
			}
			
			.site-title {
				color: white;
				font-size: 2.52rem;
				font-weight: 300;
				text-transform: uppercase;
				letter-spacing: 6px;
				margin: 0;
				padding: 0;
				text-shadow: 1px 1px 5px rgba(0, 0, 0, 0.3);
			}
			.hero-name {
				color: white;
				font-size: 3.6rem;
				font-weight: 400;
				margin: 0;
				letter-spacing: 1px;
				text-transform: uppercase;
			}

			.social-icons {
				display: flex;
				gap: 1.4rem; 
				margin-top: 0.5rem;
			}
			.social-link {
				color: rgba(255, 255, 255, 0.7);
				font-size: 2.1rem; 
				transition: color 0.3s ease, transform 0.3s ease;
				text-decoration: none;
			}
			.social-link:hover {
				color: #ffffff;
				transform: scale(1.1); 
			}

			/* VIDEO FRAME PLACEMENT - ENLARGED BY 15% */
			.video-section {
				width: 100%;
				height: 100vh;
				display: flex;
				justify-content: center;
				align-items: center;
				background: #0d0d0d;
				padding: 20px;
				box-sizing: border-box;
			}
			.video-wrapper {
				position: relative; 
				width: 100%;
				max-width: 1437px; 
				aspect-ratio: 16 / 9;
				box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.7);
				border-radius: 8px;
				overflow: hidden;
				border: 1px solid rgba(255, 255, 255, 0.05);
				cursor: pointer;
			}
			.main-video {
				width: 100%;
				height: 100%;
				display: block;
				object-fit: cover;
				background: #000000;
			}
			
			.video-blur-overlay {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background: rgba(0, 0, 0, 0.25); 
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				gap: 1.2rem;
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				text-align: center;
				pointer-events: auto;
				z-index: 5;
				transition: opacity 0.4s ease, visibility 0.4s ease;
			}
			.video-blur-overlay.hidden {
				opacity: 0;
				visibility: hidden;
				pointer-events: none;
			}
			
			.overlay-logo {
				width: 90px;
				height: auto;
				object-fit: contain;
				filter: drop-shadow(0px 4px 10px rgba(0, 0, 0, 0.4));
				margin-bottom: 0.5rem;
			}
			
			.play-icon-indicator {
				color: rgba(255, 255, 255, 0.85);
				font-size: 4.5rem;
				filter: drop-shadow(0px 4px 15px rgba(0, 0, 0, 0.6));
				transition: transform 0.3s ease;
			}
			.video-wrapper:hover .play-icon-indicator {
				transform: scale(1.08);
				color: #ffffff;
			}
			.video-subtitle {
				color: white;
				font-family: 'Paperlogy', sans-serif;
				font-size: 2.8rem; 
				font-weight: 300;
				text-transform: uppercase;
				letter-spacing: 6px;
				margin: 0;
				padding: 0;
				text-shadow: 1px 1px 5px rgba(0, 0, 0, 0.4);
			}

			/* CAROUSEL LAYOUTS */
			.carousel-header-bg {
				width: 100%;
				height: 36vh; 
				display: flex;
				justify-content: center;
				align-items: center;
				background-image: linear-gradient(rgba(0, 0, 0, 0.1), rgba(5, 5, 5, 1)), url('/ray orch.jpeg');
				background-size: cover;
				background-position: center 80%; 
				background-repeat: no-repeat;
				box-sizing: border-box;
			}
			.carousel-header-bg.orch-banner {
				background-image: linear-gradient(rgba(0, 0, 0, 0.1), rgba(5, 5, 5, 1)), url('/home is a hotel ray kim.jpeg');
				background-position: center 50%;
			}
			
			/* 1. LOWERED VIDEO GAME BANNER BY 30% -> 36.4VH HEIGHT */
			.carousel-header-bg.vg-banner {
				height: 36.4vh;
				background-image: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.9)), url('/Video Game Controller.jpeg');
				background-size: cover;
				background-position: center center;
				background-repeat: no-repeat;
			}

			.carousel-title-box {
				background: rgba(0, 0, 0, 0.4);
				padding: 1.2rem 3rem;
				border-radius: 8.8px;
				backdrop-filter: blur(6px);
				-webkit-backdrop-filter: blur(6px);
				border: 1px solid rgba(255, 255, 255, 0.1);
				text-align: center;
				margin-top: 2vh;
			}
			.carousel-section-title {
				color: white;
				font-family: 'Paperlogy', sans-serif;
				font-size: 2.5rem;
				font-weight: 300;
				text-transform: uppercase;
				letter-spacing: 5px;
				margin: 0;
				text-shadow: 0px 4px 12px rgba(0, 0, 0, 0.9);
				line-height: 1.4; 
			}

			/* Hover animation for carousel banner titles */
			.carousel-section-title {
				transition: transform 320ms cubic-bezier(.2,.9,.3,1), letter-spacing 260ms ease, text-shadow 320ms ease, color 260ms ease;
			}
			.carousel-header-bg:hover .carousel-section-title,
			.carousel-title-box:hover .carousel-section-title,
			.carousel-section-title:hover {
				transform: translateY(-6px) scale(1.02);
				letter-spacing: 7px;
				text-shadow: 0 8px 28px rgba(255,255,255,0.06), 0 6px 18px rgba(0,0,0,0.9);
				color: #ffffff;
			}

			.carousel-section {
				width: 100%;
				background: #050505; 
				box-sizing: border-box;
				padding: 10px 0 60px 0;
				position: relative;
			}
			.carousel-container {
				width: 100%;
				overflow: hidden;
				position: relative;
				padding: 20px 0;
			}
			
			.carousel-container::before,
			.carousel-container::after {
				background: linear-gradient(to right, #050505 0%, rgba(5, 5, 5, 0) 100%);
				content: "";
				height: 100%;
				position: absolute;
				width: 150px;
				z-index: 2;
				top: 0;
				pointer-events: none;
			}
			.carousel-container::before { left: 0; }
			.carousel-container::after { right: 0; transform: rotateZ(180deg); }

			.carousel-track {
				display: flex;
				width: max-content;
				gap: 2.5rem;
				animation: scroll 192.2s linear infinite;
				will-change: transform;
			}
			
			#orchCarouselTrack {
				animation: scroll 250s linear infinite;
			}

			.carousel-container:hover .carousel-track,
			.carousel-container:hover #orchCarouselTrack {
				animation-play-state: paused;
			}
			
			.poster-card {
				width: 240px;
				display: flex;
				flex-direction: column;
				position: relative;
				border-radius: 6px;
				overflow: hidden;
				box-shadow: 0 8px 25px rgba(0, 0, 0, 0.7);
				border: 1px solid rgba(255, 255, 255, 0.08);
				transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.4s ease, filter 0.4s ease;
				cursor: pointer;
				background-color: #111111;
				text-decoration: none;
			}
			.poster-number-badge {
				display: none !important;
			}
			.image-wrapper {
				width: 100%;
				aspect-ratio: 2 / 3;
				overflow: hidden;
				position: relative;
			}
			.poster-card::before {
				content: '';
				position: absolute;
				inset: 0;
				pointer-events: none;
				border-radius: 6px;
				box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.15);
				transition: box-shadow 0.25s ease, transform 0.25s ease;
				z-index: 2;
			}
			.poster-card:hover::before {
				box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.95), 0 0 45px rgba(255, 255, 255, 0.55), 0 0 30px rgba(102, 192, 244, 0.85);
				transform: scale(1.03);
			}
			.poster-card img,
			.poster-card .poster-memo {
				position: relative;
				z-index: 1;
			}
			.poster-card:hover .image-wrapper {
				box-shadow: 0 0 24px rgba(102, 192, 244, 0.22);
			}
			.poster-card img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.poster-memo {
				background: rgba(13, 13, 13, 0.9);
				color: rgba(255, 255, 255, 0.85);
				font-size: 0.72rem;
				font-weight: 300;
				text-align: center;
				padding: 0.6rem 0.4rem;
				border-top: 1px solid rgba(255, 255, 255, 0.05);
				letter-spacing: 0.5px;
				line-height: 1.3;
				white-space: normal;
				word-break: keep-all;
			}

			.poster-card:hover {
				transform: scale(1.08);
				box-shadow: 0 15px 35px rgba(0, 0, 0, 0.9), 0 0 15px rgba(255, 255, 255, 0.2);
				z-index: 10;
			}
			.carousel-track:hover .poster-card:not(:hover),
			#orchCarouselTrack:hover .poster-card:not(:hover) {
				filter: brightness(0.4) contrast(0.85);
			}

			.carousel-container:hover .carousel-track {
				animation-play-state: paused;
			}


			/* BRAND COLORIZATION TILES (DARK GREEN SLATE THEME) */
			.listen-section {
				width: 100%;
				/* background handled by pseudo-element for blurred image */
				background: none;
				padding: 80px 40px;
				box-sizing: border-box;
				position: relative;
				overflow: hidden;
				border-top: none; /* removed thin line below orchestration carousel */
			}
			.listen-section::before {
				content: "";
				position: absolute;
				inset: 0;
				background-image: url('/blog-placeholder-2.jpg');
				background-size: cover;
				background-position: center;
				filter: blur(8px) brightness(0.6) saturate(0.95);
				transform: scaleY(-1) scale(1.03); /* flip image vertically so bright area appears at top */
				transform-origin: center;
				z-index: 0;
			}
			.listen-container {
				max-width: 1400px;
				margin: 0 auto;
				position: relative;
				z-index: 1;
			}
			.listen-title-wrapper {
				text-align: center;
				margin-bottom: 50px;
			}
			.listen-main-title {
				color: white;
				font-family: 'Paperlogy', sans-serif;
				font-size: 3rem;
				font-weight: 300;
				text-transform: uppercase;
				letter-spacing: 6px;
				margin: 0;
			}
			.spotify-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 2rem;
				width: 100%;
			}
			.spotify-card {
				background: #0a140e; 
				border-radius: 12px;
				overflow: hidden;
				box-shadow: 0 8px 24px rgba(0, 0, 0, 0.6), 0 0 8px rgba(30, 215, 96, 0.2);
				border: 1px solid rgba(30, 215, 96, 0.25); 
				transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
			}
			.spotify-card:hover {
				background: #112218;
				transform: translateY(-5px);
				box-shadow: 0 14px 35px rgba(0, 0, 0, 0.8), 0 0 20px rgba(30, 215, 96, 0.5);
				border-color: #1ED760; 
			}

			/* YOUTUBE IFRAME CONTAINER FALLBACK */
			.youtube-frame {
				width: 100%;
				height: 100%;
				border: none;
				display: block;
			}

			/* PROJECT ARCHITECTURE LAYOUT WRAPPERS */
			.project-content-section {
				width: 100%;
				background: #080808;
				padding: 90px 40px;
				box-sizing: border-box;
				border-top: 1px solid rgba(255, 255, 255, 0.03);
				position: relative;
				overflow: hidden;
			}

			/* Pale Cachexia section: use a blurred background via a pseudo-element */
			.project-content-section.pale-cachexia-section {
				/* keep section layout but rely on ::before for the image + blur */
				background: none;
				padding: 90px 40px;
				box-sizing: border-box;
				border-top: none;
			}
			.project-content-section.pale-cachexia-section::before {
				content: "";
				position: absolute;
				inset: 0;
				background-image: url('/blog-placeholder-5.jpg');
				background-size: cover;
				background-position: center;
				filter: blur(8px) brightness(0.65) saturate(0.9);
				transform: scale(1.05);
				z-index: 0;
			}
			.project-content-section.pale-cachexia-section > .project-grid-container { position: relative; z-index: 1; }
			/* Combined Prometheus + Anoldor section background */
			.project-content-section.prometheus-anoldor-section { background: none; padding: 40px 40px 90px 40px; }
			.project-content-section.prometheus-anoldor-section::before {
				content: "";
				position: absolute;
				inset: 0;
				background-image: url('/blog-placeholder-4.jpg');
				background-size: cover;
				background-position: center;
				filter: blur(8px) brightness(0.6) saturate(0.9);
				transform: scale(1.05);
				z-index: 0;
			}
			.project-content-section.prometheus-anoldor-section > .project-grid-container { position: relative; z-index: 1; }
			.project-grid-container {
				max-width: 1250px;
				margin: 0 auto;
				display: grid;
				grid-template-columns: 4.5fr 7.5fr;
				gap: 4.5rem;
				align-items: center;
			}
			.project-left-col {
				width: 100%;
				display: flex;
				justify-content: center;
			}
			.project-image-frame {
				width: 100%;
				/* increased max-width by 25% (370 * 1.25 = 462.5) */
				max-width: 463px;
				/* removed fixed portrait aspect-ratio so horizontal banners keep their shape */
				border-radius: 10px;
				overflow: hidden;
				position: relative;
				box-shadow: 0 12px 35px rgba(0, 0, 0, 0.85);
				border: 1px solid rgba(255, 255, 255, 0.08);
				transition: transform 0.45s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.45s ease;
			}

			.project-image-frame:hover {
				transform: scale(1.05) translateY(-5px);
				box-shadow: 0 20px 45px rgba(0, 0, 0, 0.95), 0 0 15px rgba(255, 255, 255, 0.1);
			}
			.project-image-frame img {
				width: 100%;
				height: auto;
				display: block;
			}

			/* specific background for the Pale Cachexia banner container */
			/* removed individual frame background for pale cachexia; section-level background handles it */
			.project-right-col {
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				color: #e0e0e0;
			}
			.project-header-title {
				color: #ffffff;
				font-family: 'Paperlogy', sans-serif;
				font-size: 2.85rem;
				font-weight: 500;
				margin: 0 0 1.8rem 0;
				letter-spacing: 1px;
				text-shadow: 0 2px 8px rgba(0,0,0,0.5);
			}
			.project-description-paragraph {
				font-family: 'Pretendard', sans-serif;
				font-size: 1.15rem;
				font-weight: 300;
				line-height: 1.95;
				margin: 0 0 2.5rem 0;
				color: rgba(255, 255, 255, 0.85);
				word-break: keep-all;
			}
			
			/* REDIRECT PLATFORM ACTION BUTTONS */
			.store-redirect-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.85rem;
				background: linear-gradient(135deg, #10253f 0%, #171a21 100%);
				color: #ffffff;
				padding: 1.05rem 2.2rem;
				font-family: 'Paperlogy', sans-serif;
				font-size: 1.05rem;
				font-weight: 500;
				letter-spacing: 1px;
				text-transform: uppercase;
				text-decoration: none;
				border-radius: 6px;
				border: 1px solid rgba(102, 192, 244, 0.3);
				box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
				transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
			}
			.store-redirect-btn:hover {
				background: linear-gradient(135deg, #143660 0%, #1b2838 100%);
				border-color: #66c0f4;
				transform: translateY(-2px);
				box-shadow: 0 10px 25px rgba(102, 192, 244, 0.25);
			}
			.store-redirect-btn i {
				font-size: 1.35rem;
				color: #66c0f4;
				transition: transform 0.3s ease;
			}
			.store-redirect-btn:hover i {
				transform: scale(1.15);
			}

			/* ITCH IO SPECIFIC ACTION OVERRIDES */
			.store-redirect-btn.itch-theme {
				background: linear-gradient(135deg, #332222 0%, #141414 100%);
				border-color: rgba(250, 92, 92, 0.3);
			}
			.store-redirect-btn.itch-theme:hover {
				background: linear-gradient(135deg, #5c2c2c 0%, #2b1616 100%);
				border-color: #fa5c5c;
				box-shadow: 0 10px 25px rgba(250, 92, 92, 0.25);
			}
			.store-redirect-btn.itch-theme i {
				color: #fa5c5c;
			}

			@keyframes scroll {
				0% { transform: translateX(0); }
				100% { transform: translateX(calc(-50% - 1.25rem)); } 
			}

			@media (max-width: 1200px) {
				.spotify-grid { grid-template-columns: repeat(2, 1fr); }
				.project-grid-container { gap: 3rem; }
				.project-header-title { font-size: 2.3rem; }
			}

			@media (max-width: 768px) {
				.site-navbar { padding: 1rem 1.5rem; }
				.navbar-brand { font-size: 1rem; }
				.logo-wrapper { top: 10vh; }
				.site-logo { width: 80px; }
