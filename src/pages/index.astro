---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		
		<!-- 1. LOAD FONT AWESOME FOR THE ICONS -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

		<style>
			/* Import the Paperlogy font family */
			@import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css');
			@font-face {
				font-family: 'Paperlogy';
				src: url('https://fastly.jsdelivr.net/gh/projectnoonnu/2411-3@1.0/Paperlogy-Thin.woff2') format('woff2');
				font-weight: 300;
			}
			@font-face {
				font-family: 'Paperlogy';
				src: url('https://fastly.jsdelivr.net/gh/projectnoonnu/2411-3@1.0/Paperlogy-Medium.woff2') format('woff2');
				font-weight: 500;
			}

			html, body {
				margin: 0;
				padding: 0;
				width: 100%;
				height: 100%;
				overflow-x: hidden;
				overflow-y: auto;
				scroll-behavior: smooth;
				font-family: 'Paperlogy', 'Pretendard', sans-serif;
				background-color: #000000;
			}
			.hero-container {
				position: relative;
				width: 100%;
				height: 100vh;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				background-image: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2)), url('/Ray Conduct.JPG');
				background-size: cover;
				background-position: center;
				background-repeat: no-repeat;
			}
			.logo-wrapper {
				position: absolute;
				top: 8vh;
				left: 50%;
				transform: translateX(-50%);
				z-index: 10;
			}
			.site-logo {
				width: 110px; 
				height: auto;
				object-fit: contain;
				filter: drop-shadow(0px 4px 12px rgba(0, 0, 0, 0.5));
			}
			.text-overlay {
				background: rgba(0, 0, 0, 0.25);
				padding: 2.5rem 4rem;
				border-radius: 12px;
				backdrop-filter: blur(8px);
				-webkit-backdrop-filter: blur(8px);
				border: 1px solid rgba(255, 255, 255, 0.1);
				text-align: center;
				max-width: 80%;
				margin-top: 10vh;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 1.5rem;
			}
			.site-title {
				color: white;
				font-size: 3.5rem;
				font-weight: 300;
				text-transform: uppercase;
				letter-spacing: 6px;
				margin: 0;
				padding: 0;
				text-shadow: 1px 1px 5px rgba(0, 0, 0, 0.3);
			}

			/* 2. STYLE THE SOCIAL ICONS CONTAINER */
			.social-icons {
				display: flex;
				gap: 1.4rem; 
				margin-top: 0.5rem;
			}
			.social-link {
				color: rgba(255, 255, 255, 0.7);
				font-size: 2.1rem; 
				transition: color 0.3s ease, transform 0.3s ease;
				text-decoration: none;
			}
			.social-link:hover {
				color: #ffffff;
				transform: scale(1.1); 
			}

			/* 3. STYLE THE SCROLLABLE SECOND PAGE (VIDEO PLACEMENT) */
			.video-section {
				width: 100%;
				height: 100vh;
				display: flex;
				justify-content: center;
				align-items: center;
				background: #0d0d0d;
				padding: 20px;
				box-sizing: border-box;
			}
			.video-wrapper {
				position: relative; 
				width: 100%;
				max-width: 1250px;
				aspect-ratio: 16 / 9;
				box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.7);
				border-radius: 8px;
				overflow: hidden;
				border: 1px solid rgba(255, 255, 255, 0.05);
			}
			.main-video {
				width: 100%;
				height: 100%;
				display: block;
				object-fit: cover;
				background: #000000;
			}
			.video-blur-overlay {
				position: absolute;
				top: 50%;
				left: 50%;
				transform: translate(-50%, -50%);
				background: rgba(0, 0, 0, 0.35); 
				padding: 2rem 4rem;
				border-radius: 12px;
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
				border: 1px solid rgba(255, 255, 255, 0.1);
				text-align: center;
				pointer-events: none; 
				z-index: 5;
				transition: opacity 0.4s ease;
			}
			.video-subtitle {
				color: white;
				font-family: 'Paperlogy', sans-serif;
				font-size: 3.15rem; 
				font-weight: 300;
				text-transform: uppercase;
				letter-spacing: 6px;
				margin: 0;
				padding: 0;
				text-shadow: 1px 1px 5px rgba(0, 0, 0, 0.4);
				white-space: nowrap;
			}

			/* 4. STYLE THE THIRD PAGE (FEATURES & SERIES CAROUSEL) */
			.carousel-section {
				width: 100%;
				height: 100vh;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				background: #050505; 
				overflow: hidden;
				box-sizing: border-box;
				padding: 40px 0;
			}
			.carousel-title-box {
				background: rgba(255, 255, 255, 0.03);
				padding: 1.2rem 3rem;
				border-radius: 8px;
				backdrop-filter: blur(6px);
				-webkit-backdrop-filter: blur(6px);
				border: 1px solid rgba(255, 255, 255, 0.05);
				margin-bottom: 4vh;
				text-align: center;
			}
			.carousel-section-title {
				color: white;
				font-family: 'Paperlogy', sans-serif;
				font-size: 2.5rem;
				font-weight: 300;
				text-transform: uppercase;
				letter-spacing: 5px;
				margin: 0;
				text-shadow: 0px 4px 10px rgba(0, 0, 0, 0.5);
			}
			.carousel-container {
				width: 100%;
				overflow: hidden;
				position: relative;
				padding: 20px 0;
			}
			.carousel-container::before,
			.carousel-container::after {
				background: linear-gradient(to right, #050505 0%, rgba(5, 5, 5, 0) 100%);
				content: "";
				height: 100%;
				position: absolute;
				width: 150px;
				z-index: 2;
				top: 0;
				pointer-events: none;
			}
			.carousel-container::before { left: 0; }
			.carousel-container::after { right: 0; transform: rotateZ(180deg); }

			.carousel-track {
				display: flex;
				width: max-content;
				gap: 2.5rem;
				animation: scroll 65s linear infinite; 
			}
			.carousel-container:hover .carousel-track {
				animation-play-state: paused;
			}
			
			.poster-card {
				width: 240px;
				aspect-ratio: 2 / 3;
				border-radius: 6px;
				overflow: hidden;
				box-shadow: 0 8px 20px rgba(0, 0, 0, 0.5);
				border: 1px solid rgba(255, 255, 255, 0.08);
				transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.4s ease, filter 0.4s ease;
				cursor: pointer;
				background-color: #111111;
			}
			.poster-card img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.poster-card:hover {
				transform: scale(1.08);
				box-shadow: 0 15px 35px rgba(0, 0, 0, 0.8), 0 0 15px rgba(255, 255, 255, 0.15);
				z-index: 10;
			}
			.carousel-track:hover .poster-card:not(:hover) {
				filter: brightness(0.5) contrast(0.85);
			}

			@keyframes scroll {
				0% { transform: translateX(0); }
				100% { transform: translateX(calc(-50% - 1.25rem)); } 
			}

			@media (max-width: 768px) {
				.logo-wrapper { top: 6vh; }
				.site-logo { width: 80px; }
				.text-overlay { padding: 1.5rem 2rem; margin-top: 8vh; }
				.site-title { font-size: 2.2rem; letter-spacing: 4px; }
				.social-link { font-size: 1.7rem; }
				.video-section { height: auto; padding: 60px 20px; }
				.video-blur-overlay { padding: 1rem 2rem; }
				.video-subtitle { font-size: 1.98rem; letter-spacing: 4px; }
				
				.carousel-section { height: auto; padding: 60px 0; }
				.carousel-section-title { font-size: 1.8rem; letter-spacing: 3px; }
				.carousel-title-box { padding: 0.8rem 1.5rem; }
				.poster-card { width: 160px; }
				@keyframes scroll {
					0% { transform: translateX(0); }
					100% { transform: translateX(calc(-50% - 1.25rem)); }
				}
			}
		</style>
	</head>
	<body>
		<!-- FIRST PAGE: LANDING HERO -->
		<main class="hero-container">
			<div class="logo-wrapper">
				<img src="/iTunesArtwork@2x.png" alt="Superrray Productions Logo" class="site-logo" />
			</div>
			
			<div class="text-overlay">
				<h1 class="site-title">Superrray Productions</h1>
				<div class="social-icons">
					<a href="https://www.imdb.com/name/nm8105113/" target="_blank" class="social-link" aria-label="IMDb"><i class="fa-brands fa-imdb"></i></a>
					<a href="https://www.instagram.com/doraymekim/" target="_blank" class="social-link" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
					<a href="https://music.apple.com/us/artist/ray-d-kim/780192649" target="_blank" class="social-link" aria-label="Apple Music"><i class="fa-brands fa-apple"></i></a>
					<a href="https://open.spotify.com/artist/1JHFQv8E0HG7mmKpuftPLB?trackId=6DDJvEGIgYBg4oO6kdh1AF" target="_blank" class="social-link" aria-label="Spotify"><i class="fa-brands fa-spotify"></i></a>
				</div>
			</div>
		</main>

		<!-- SECOND PAGE: SCROLLABLE VIDEO PLACEMENT WITH GAUSSIAN BLUR CARD -->
		<section class="video-section">
			<div class="video-wrapper">
				<div class="video-blur-overlay">
					<h2 class="video-subtitle">Film Reel</h2>
				</div>
				<video controls preload="metadata" class="main-video" poster="/Ray Conduct.JPG">
					<source src="https://www.dropbox.com/scl/fi/99aszddtu6zz9e2v2yrmr/Film-Reel-250705-24-rf23.mp4?rlkey=gbv08rw12a2w8r72eowok3hpt&st=6hj8hsfb&raw=1" type="video/mp4" />
					Your browser does not support the video tag.
				</video>
			</div>
		</section>

		<!-- THIRD PAGE: SCROLLABLE "FEATURES & SERIES" AUTO-PLAY CAROUSEL -->
		<section class="carousel-section">
			<div class="carousel-title-box">
				<h2 class="carousel-section-title">Features & Series</h2>
			</div>

			<div class="carousel-container">
				<div class="carousel-track">
					<!-- Set A: Active Movie Posters from your public directory -->
					<div class="poster-card"><img src="/hacks%20season%205.png" alt="Hacks Season 5" /></div>
					<div class="poster-card"><img src="/hacks%20season%204.png" alt="Hacks Season 4" /></div>
					<div class="poster-card"><img src="/heals.png" alt="Heals" /></div>
					<div class="poster-card"><img src="/ILNY_PostersBlack.jpg" alt="ILNY Posters Black" /></div>
					<div class="poster-card"><img src="/Lessons%20in%20Chemistry.png" alt="Lessons in Chemistry" /></div>
					<div class="poster-card"><img src="/They%20Will%20Kill%20You.png" alt="They Will Kill You" /></div>
					<div class="poster-card"><img src="/chupa.jpg" alt="Chupa" /></div>
					<div class="poster-card"><img src="/death%20and%20other%20details.png" alt="Death and Other Details" /></div>
					<div class="poster-card"><img src="/dept%20q.png" alt="Dept Q" /></div>
					<div class="poster-card"><img src="/ezra.jpeg" alt="Ezra" /></div>
					<div class="poster-card"><img src="/griselda%202.jpeg" alt="Griselda 2" /></div>
					<div class="poster-card"><img src="/hacks%203.jpeg" alt="Hacks 3" /></div>
					<div class="poster-card"><img src="/hacks%20season%201.png" alt="Hacks Season 1" /></div>
					<div class="poster-card"><img src="/hacks%20season%202.png" alt="Hacks Season 2" /></div>
					<div class="poster-card"><img src="/just%20beyond.png" alt="Just Beyond" /></div>
					<div class="poster-card"><img src="/la%20reina%20del%20sur.png" alt="La Reina Del Sur" /></div>
					<div class="poster-card"><img src="/monsieur%20spade%202.png" alt="Monsieur Spade 2" /></div>

					<!-- Set B: Duplicate set for seamless looping -->
					<div class="poster-card"><img src="/hacks%20season%205.png" alt="Hacks Season 5 Duplicate" /></div>
					<div class="poster-card"><img src="/hacks%20season%204.png" alt="Hacks Season 4 Duplicate" /></div>
					<div class="poster-card"><img src="/heals.png" alt="Heals Duplicate" /></div>
					<div class="poster-card"><img src="/ILNY_PostersBlack.jpg" alt="ILNY Posters Black Duplicate" /></div>
					<div class="poster-card"><img src="/Lessons%20in%20Chemistry.png" alt="Lessons in Chemistry Duplicate" /></div>
					<div class="poster-card"><img src="/They%20Will%20Kill%20You.png" alt="They Will Kill You Duplicate" /></div>
					<div class="poster-card"><img src="/chupa.jpg" alt="Chupa Duplicate" /></div>
					<div class="poster-card"><img src="/death%20and%20other%20details.png" alt="Death and Other Details Duplicate" /></div>
					<div class="poster-card"><img src="/dept%20q.png" alt="Dept Q Duplicate" /></div>
					<div class="poster-card"><img src="/ezra.jpeg" alt="Ezra Duplicate" /></div>
					<div class="poster-card"><img src="/griselda%202.jpeg" alt="Griselda 2 Duplicate" /></div>
					<div class="poster-card"><img src="/hacks%203.jpeg" alt="Hacks 3 Duplicate" /></div>
					<div class="poster-card"><img src="/hacks%20season%201.png" alt="Hacks Season 1 Duplicate" /></div>
					<div class="poster-card"><img src="/hacks%20season%202.png" alt="Hacks Season 2 Duplicate" /></div>
					<div class="poster-card"><img src="/just%20beyond.png" alt="Just Beyond Duplicate" /></div>
					<div class="poster-card"><img src="/la%20reina%20del%20sur.png" alt="La Reina Del Sur Duplicate" /></div>
					<div class="poster-card"><img src="/monsieur%20spade%202.png" alt="Monsieur Spade 2 Duplicate" /></div>
				</div>
			</div>
		</section>
	</body>
</html>
