---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
	/* Import the Paperlogy font family */
	@import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css'); /* Fallback modern geometric font */
	@font-face {
		font-family: 'Paperlogy';
		src: url('https://fastly.jsdelivr.net/gh/projectnoonnu/2411-3@1.0/Paperlogy-Thin.woff2') format('woff2');
		font-weight: 300;
	}
	@font-face {
		font-family: 'Paperlogy';
		src: url('https://fastly.jsdelivr.net/gh/projectnoonnu/2411-3@1.0/Paperlogy-Medium.woff2') format('woff2');
		font-weight: 500;
	}

	html, body {
		margin: 0;
		padding: 0;
		width: 100%;
		height: 100%;
		overflow: hidden;
		font-family: 'Paperlogy', 'Pretendard', sans-serif;
	}
	.hero-container {
		position: relative;
		width: 100%;
		height: 100vh;
		display: flex;
		justify-content: center;
		align-items: center;
		background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url('/Ray Conduct.JPG');
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
	}
	.site-title {
		color: white;
		font-size: 3.5rem;
		/* Changed from 800 (very fat) to 300 (elegant & thin) */
		font-weight: 300; 
		text-transform: uppercase;
		letter-spacing: 6px; /* Slightly increased spacing for a premium look */
		text-align: center;
		text-shadow: 1px 1px 8px rgba(0, 0, 0, 0.5);
		margin: 0;
		padding: 0 20px;
	}
	@media (max-width: 768px) {
		.site-title {
			font-size: 2.2rem;
			letter-spacing: 4px;
		}
	}
</style>
	</head>
	<body>
		<main class="hero-container">
			<h1 class="site-title">Superrray Productions</h1>
		</main>
	</body>
</html>
