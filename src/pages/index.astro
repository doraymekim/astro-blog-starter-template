		<!-- SCRIPT TO HANDLE VIDEO BLUR & MANUAL ARROW CLICK TIMING -->
		<script>
			// Video overlay management
			const video = document.getElementById('filmReelVideo');
			const overlay = document.getElementById('videoOverlay');

			if (video && overlay) {
				video.addEventListener('play', () => overlay.classList.add('hidden'));
				video.addEventListener('pause', () => overlay.classList.remove('hidden'));
			}

			// Manual arrow controls for Section 1 (Features & Series)
			const container = document.getElementById('carouselContainer');
			const prevBtn = document.getElementById('prevBtn');
			const nextBtn = document.getElementById('nextBtn');
			const scrollAmount = 400; // Pixels to bump layout horizontally per click

			if (container && prevBtn && nextBtn) {
				prevBtn.addEventListener('click', () => {
					container.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
				});
				
				nextBtn.addEventListener('click', () => {
					container.scrollBy({ left: scrollAmount, behavior: 'smooth' });
				});
			}

			// Manual arrow controls for Section 2 (Orchestration, Programming & Score Supervision)
			const orchContainer = document.getElementById('orchCarouselContainer');
			const orchPrevBtn = document.getElementById('orchPrevBtn');
			const orchNextBtn = document.getElementById('orchNextBtn');

			if (orchContainer && orchPrevBtn && orchNextBtn) {
				orchPrevBtn.addEventListener('click', () => {
					orchContainer.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
				});
				
				orchNextBtn.addEventListener('click', () => {
					orchContainer.scrollBy({ left: scrollAmount, behavior: 'smooth' });
				});
			}
		</script>
