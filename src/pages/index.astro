---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Updating the browser tab name variables here
const SITE_TITLE = "Superrray Productions";
const SITE_DESCRIPTION = "Composer & Score Supervisor Portfolio";
---

<!doctype html>
<html lang="en">
	<head>
		<!-- Pass the updated site title directly to your head component -->
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		
		<!-- FAVICON SOURCE ENFORCED -->
		<link rel="icon" type="image/png" href="/iTunesArtwork@2x.png?v=2" />
		<link rel="apple-touch-icon" href="/iTunesArtwork@2x.png?v=2" />
		
		<!-- LOAD FONT AWESOME FOR ICONS -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

		<style>
			@import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css');
			@font-face {
				font-family: 'Paperlogy';
				src: url('https://fastly.jsdelivr.net/gh/projectnoonnu/2411-3@1.0/Paperlogy-Thin.woff2') format('woff2');
				font-weight: 300;
			}
			@font-face {
				font-family: 'Paperlogy';
				src: url('https://fastly.jsdelivr.net/gh/projectnoonnu/2411-3@1.0/Paperlogy-Medium.woff2') format('woff2');
				font-weight: 500;
			}

			html, body {
				margin: 0;
				padding: 0;
				width: 100%;
				height: 100%;
				overflow-x: hidden;
				overflow-y: auto;
				scroll-behavior: smooth;
				font-family: 'Paperlogy', 'Pretendard', sans-serif;
				background-color: #000000;
			}
			
			/* NAVBAR LOGO POSITIONING */
			.site-navbar {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				padding: 1.5rem 3rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
				z-index: 100;
				background: linear-gradient(to bottom, rgba(0,0,0,0.7), rgba(0,0,0,0));
			}
			.navbar-brand {
				color: white;
				font-size: 1.3rem;
				font-weight: 500;
				text-transform: uppercase;
				letter-spacing: 2px;
				text-decoration: none;
			}

			/* HERO LAYER BACKGROUND */
			.hero-container {
				position: relative;
				width: 100%;
				height: 100vh;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				background-image: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2)), url('/Ray Conduct.JPG');
				background-size: cover;
				background-position: center;
				background-repeat: no-repeat;
			}
			.logo-wrapper {
				position: absolute;
				top: 12vh;
				left: 50%;
				transform: translateX(-50%);
				z-index: 10;
			}
			.site-logo {
				width: 110px; 
				height: auto;
				object-fit: contain;
				filter: drop-shadow(0px 4px 12px rgba(0, 0, 0, 0.5));
			}
			
			/* HERO TEXT OVERLAY & FROSTED GLASS ADJUSTMENT */
			.text-overlay {
				background: rgba(0, 0, 0, 0.25);
				padding: 2.5rem 4rem;
				border-radius: 13.2px; 
				backdrop-filter: blur(8px);
				-webkit-backdrop-filter: blur(8px);
				border: 1px solid rgba(255, 255, 255, 0.1);
				text-align: center;
				max-width: 80%;
				margin-top: 10vh;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 1.5rem;
			}
			
			.site-title {
				color: white;
				font-size: 2.52rem;
				font-weight: 300;
				text-transform: uppercase;
				letter-spacing: 6px;
				margin: 0;
				padding: 0;
				text-shadow: 1px 1px 5px rgba(0, 0, 0, 0.3);
			}

			.social-icons {
				display: flex;
				gap: 1.4rem; 
				margin-top: 0.5rem;
			}
			.social-link {
				color: rgba(255, 255, 255, 0.7);
				font-size: 2.1rem; 
				transition: color 0.3s ease, transform 0.3s ease;
				text-decoration: none;
			}
			.social-link:hover {
				color: #ffffff;
				transform: scale(1.1); 
			}

			/* VIDEO FRAME PLACEMENT - ENLARGED BY 15% */
			.video-section {
				width: 100%;
				height: 100vh;
				display: flex;
				justify-content: center;
				align-items: center;
				background: #0d0d0d;
				padding: 20px;
				box-sizing: border-box;
			}
			.video-wrapper {
				position: relative; 
				width: 100%;
				max-width: 1437px; 
				aspect-ratio: 16 / 9;
				box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.7);
				border-radius: 8px;
				overflow: hidden;
				border: 1px solid rgba(255, 255, 255, 0.05);
				cursor: pointer;
			}
			.main-video {
				width: 100%;
				height: 100%;
				display: block;
				object-fit: cover;
				background: #000000;
			}
			
			.video-blur-overlay {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background: rgba(0, 0, 0, 0.25); 
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				gap: 1.2rem;
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				text-align: center;
				pointer-events: none; 
				z-index: 5;
				transition: opacity 0.4s ease, visibility 0.4s ease;
			}
			.video-blur-overlay.hidden {
				opacity: 0;
				visibility: hidden;
			}
			
			.overlay-logo {
				width: 90px;
				height: auto;
				object-fit: contain;
				filter: drop-shadow(0px 4px 10px rgba(0, 0, 0, 0.4));
				margin-bottom: 0.5rem;
			}
			
			.play-icon-indicator {
				color: rgba(255, 255, 255, 0.85);
				font-size: 4.5rem;
				filter: drop-shadow(0px 4px 15px rgba(0, 0, 0, 0.6));
				transition: transform 0.3s ease;
			}
			.video-wrapper:hover .play-icon-indicator {
				transform: scale(1.08);
				color: #ffffff;
			}
			.video-subtitle {
				color: white;
				font-family: 'Paperlogy', sans-serif;
				font-size: 2.8rem; 
				font-weight: 300;
				text-transform: uppercase;
				letter-spacing: 6px;
				margin: 0;
				padding: 0;
				text-shadow: 1px 1px 5px rgba(0, 0, 0, 0.4);
			}

			/* CAROUSEL LAYOUTS */
			.carousel-header-bg {
				width: 100%;
				height: 36vh; 
				display: flex;
				justify-content: center;
				align-items: center;
				background-image: linear-gradient(rgba(0, 0, 0, 0.1), rgba(5, 5, 5, 1)), url('/ray orch.jpeg');
				background-size: cover;
				background-position: center 80%; 
				background-repeat: no-repeat;
				box-sizing: border-box;
			}
			.carousel-header-bg.orch-banner {
				background-image: linear-gradient(rgba(0, 0, 0, 0.1), rgba(5, 5, 5, 1)), url('/home is a hotel ray kim.jpeg');
				background-position: center 50%;
			}
			
			/* 1. LOWERED VIDEO GAME BANNER BY 30% -> 36.4VH HEIGHT */
			.carousel-header-bg.vg-banner {
				height: 36.4vh;
				background-image: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.9)), url('/Video Game Controller.jpeg');
				background-size: cover;
				background-position: center center;
				background-repeat: no-repeat;
			}

			.carousel-title-box {
				background: rgba(0, 0, 0, 0.4);
				padding: 1.2rem 3rem;
				border-radius: 8.8px;
				backdrop-filter: blur(6px);
				-webkit-backdrop-filter: blur(6px);
				border: 1px solid rgba(255, 255, 255, 0.1);
				text-align: center;
				margin-top: 2vh;
			}
			.carousel-section-title {
				color: white;
				font-family: 'Paperlogy', sans-serif;
				font-size: 2.5rem;
				font-weight: 300;
				text-transform: uppercase;
				letter-spacing: 5px;
				margin: 0;
				text-shadow: 0px 4px 12px rgba(0, 0, 0, 0.9);
				line-height: 1.4; 
			}

			.carousel-section {
				width: 100%;
				background: #050505; 
				box-sizing: border-box;
				padding: 10px 0 60px 0;
				position: relative;
			}
			.carousel-container {
				width: 100%;
				overflow: hidden;
				position: relative;
				padding: 20px 0;
			}
			
			.carousel-container::before,
			.carousel-container::after {
				background: linear-gradient(to right, #050505 0%, rgba(5, 5, 5, 0) 100%);
				content: "";
				height: 100%;
				position: absolute;
				width: 150px;
				z-index: 2;
				top: 0;
				pointer-events: none;
			}
			.carousel-container::before { left: 0; }
			.carousel-container::after { right: 0; transform: rotateZ(180deg); }

			.carousel-track {
				display: flex;
				width: max-content;
				gap: 2.5rem;
				animation: scroll 82.2s linear infinite; 
				will-change: transform;
				transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
			}
			
			#orchCarouselTrack {
				animation: scroll 98.6s linear infinite;
				transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
			}

			.carousel-track:hover,
			#orchCarouselTrack:hover {
				animation-play-state: paused;
			}
			
			.poster-card {
				width: 240px;
				display: flex;
				flex-direction: column;
				position: relative;
				border-radius: 6px;
				overflow: hidden;
				box-shadow: 0 8px 25px rgba(0, 0, 0, 0.7);
				border: 1px solid rgba(255, 255, 255, 0.08);
				transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.4s ease, filter 0.4s ease;
				cursor: pointer;
				background-color: #111111;
				text-decoration: none;
			}
			.image-wrapper {
				width: 100%;
				aspect-ratio: 2 / 3;
				overflow: hidden;
			}
			.poster-card img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.poster-memo {
				background: rgba(13, 13, 13, 0.9);
				color: rgba(255, 255, 255, 0.85);
				font-size: 0.72rem;
				font-weight: 300;
				text-align: center;
				padding: 0.6rem 0.4rem;
				border-top: 1px solid rgba(255, 255, 255, 0.05);
				letter-spacing: 0.5px;
				line-height: 1.3;
				white-space: normal;
				word-break: keep-all;
			}

			.poster-card:hover {
				transform: scale(1.08);
				box-shadow: 0 15px 35px rgba(0, 0, 0, 0.9), 0 0 15px rgba(255, 255, 255, 0.2);
				z-index: 10;
			}
			.carousel-track:hover .poster-card:not(:hover),
			#orchCarouselTrack:hover .poster-card:not(:hover) {
				filter: brightness(0.4) contrast(0.85);
			}

			.carousel-arrow {
				position: absolute;
				top: 50%;
				transform: translateY(-50%);
				background: rgba(0, 0, 0, 0.65);
				border: 1px solid rgba(255, 255, 255, 0.2);
				color: rgba(255, 255, 255, 0.7);
				width: 50px;
				height: 50px;
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 1.25rem;
				cursor: pointer;
				z-index: 25; 
				transition: all 0.3s ease;
				backdrop-filter: blur(4px);
				-webkit-backdrop-filter: blur(4px);
			}
			.carousel-arrow:hover {
				background: rgba(255, 255, 255, 0.9);
				color: #000000;
				border-color: #ffffff;
				box-shadow: 0 0 15px rgba(255, 255, 255, 0.3);
			}
			.carousel-arrow.left { left: 25px; }
			.carousel-arrow.right { right: 25px; }

			/* BRAND COLORIZATION TILES (DARK GREEN SLATE THEME) */
			.listen-section {
				width: 100%;
				background: #030604;
				padding: 80px 40px;
				box-sizing: border-box;
				border-top: 1px solid rgba(255, 255, 255, 0.05);
			}
			.listen-container {
				max-width: 1400px;
				margin: 0 auto;
			}
			.listen-title-wrapper {
				text-align: center;
				margin-bottom: 50px;
			}
			.listen-main-title {
				color: white;
				font-family: 'Paperlogy', sans-serif;
				font-size: 3rem;
				font-weight: 300;
				text-transform: uppercase;
				letter-spacing: 6px;
				margin: 0;
			}
			.spotify-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 2rem;
				width: 100%;
			}
			.spotify-card {
				background: #0a140e; 
				border-radius: 12px;
				overflow: hidden;
				box-shadow: 0 8px 24px rgba(0, 0, 0, 0.6), 0 0 8px rgba(30, 215, 96, 0.2);
				border: 1px solid rgba(30, 215, 96, 0.25); 
				transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
			}
			.spotify-card:hover {
				background: #112218;
				transform: translateY(-5px);
				box-shadow: 0 14px 35px rgba(0, 0, 0, 0.8), 0 0 20px rgba(30, 215, 96, 0.5);
				border-color: #1ED760; 
			}

			/* YOUTUBE IFRAME CONTAINER FALLBACK */
			.youtube-frame {
				width: 100%;
				height: 100%;
				border: none;
				display: block;
			}

			/* PROJECT ARCHITECTURE LAYOUT WRAPPERS */
			.project-content-section {
				width: 100%;
				background: #080808;
				padding: 90px 40px;
				box-sizing: border-box;
				border-top: 1px solid rgba(255, 255, 255, 0.03);
			}
			.project-grid-container {
				max-width: 1250px;
				margin: 0 auto;
				display: grid;
				grid-template-columns: 4.5fr 7.5fr;
				gap: 4.5rem;
				align-items: center;
			}
			.project-left-col {
				width: 100%;
				display: flex;
				justify-content: center;
			}
			.project-image-frame {
				width: 100%;
				max-width: 370px;
				aspect-ratio: 2 / 3;
				border-radius: 10px;
				overflow: hidden;
				box-shadow: 0 12px 35px rgba(0, 0, 0, 0.85);
				border: 1px solid rgba(255, 255, 255, 0.08);
				transition: transform 0.45s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.45s ease;
			}
			.project-image-frame:hover {
				transform: scale(1.05) translateY(-5px);
				box-shadow: 0 20px 45px rgba(0, 0, 0, 0.95), 0 0 15px rgba(255, 255, 255, 0.1);
			}
			.project-image-frame img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.project-right-col {
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				color: #e0e0e0;
			}
			.project-header-title {
				color: #ffffff;
				font-family: 'Paperlogy', sans-serif;
				font-size: 2.85rem;
				font-weight: 500;
				margin: 0 0 1.8rem 0;
				letter-spacing: 1px;
				text-shadow: 0 2px 8px rgba(0,0,0,0.5);
			}
			.project-description-paragraph {
				font-family: 'Pretendard', sans-serif;
				font-size: 1.15rem;
				font-weight: 300;
				line-height: 1.95;
				margin: 0 0 2.5rem 0;
				color: rgba(255, 255, 255, 0.85);
				word-break: keep-all;
			}
			
			/* REDIRECT PLATFORM ACTION BUTTONS */
			.store-redirect-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.85rem;
				background: linear-gradient(135deg, #10253f 0%, #171a21 100%);
				color: #ffffff;
				padding: 1.05rem 2.2rem;
				font-family: 'Paperlogy', sans-serif;
				font-size: 1.05rem;
				font-weight: 500;
				letter-spacing: 1px;
				text-transform: uppercase;
				text-decoration: none;
				border-radius: 6px;
				border: 1px solid rgba(102, 192, 244, 0.3);
				box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
				transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
			}
			.store-redirect-btn:hover {
				background: linear-gradient(135deg, #143660 0%, #1b2838 100%);
				border-color: #66c0f4;
				transform: translateY(-2px);
				box-shadow: 0 10px 25px rgba(102, 192, 244, 0.25);
			}
			.store-redirect-btn i {
				font-size: 1.35rem;
				color: #66c0f4;
				transition: transform 0.3s ease;
			}
			.store-redirect-btn:hover i {
				transform: scale(1.15);
			}

			/* ITCH IO SPECIFIC ACTION OVERRIDES */
			.store-redirect-btn.itch-theme {
				background: linear-gradient(135deg, #332222 0%, #141414 100%);
				border-color: rgba(250, 92, 92, 0.3);
			}
			.store-redirect-btn.itch-theme:hover {
				background: linear-gradient(135deg, #5c2c2c 0%, #2b1616 100%);
				border-color: #fa5c5c;
				box-shadow: 0 10px 25px rgba(250, 92, 92, 0.25);
			}
			.store-redirect-btn.itch-theme i {
				color: #fa5c5c;
			}

			@keyframes scroll {
				0% { transform: translateX(0); }
				100% { transform: translateX(calc(-50% - 1.25rem)); } 
			}

			@media (max-width: 1200px) {
				.spotify-grid { grid-template-columns: repeat(2, 1fr); }
				.project-grid-container { gap: 3rem; }
				.project-header-title { font-size: 2.3rem; }
			}

			@media (max-width: 768px) {
				.site-navbar { padding: 1rem 1.5rem; }
				.navbar-brand { font-size: 1rem; }
				.logo-wrapper { top: 10vh; }
				.site-logo { width: 80px; }
				.text-overlay { padding: 1.5rem 2rem; margin-top: 8vh; }
				.site-title { font-size: 1.8rem; letter-spacing: 4px; }
				.social-link { font-size: 1.7rem; }
				.video-section { height: auto; padding: 60px 20px; }
				.overlay-logo { width: 65px; }
				.play-icon-indicator { font-size: 3.2rem; }
				.video-subtitle { font-size: 1.8rem; letter-spacing: 4px; }
				
				.carousel-header-bg { height: 24vh; background-position: center 75%; }
				.carousel-header-bg.vg-banner { height: 32vh; background-size: cover; }
				.carousel-section { padding-bottom: 40px; }
				.carousel-section-title { font-size: 1.8rem; letter-spacing: 3px; }
				.carousel-title-box { padding: 0.8rem 1.5rem; }
				.poster-card { width: 160px; }
				.poster-memo { font-size: 0.6rem; padding: 0.4rem 0.2rem; }
				.carousel-arrow { width: 40px; height: 40px; font-size: 1rem; }
				.carousel-arrow.left { left: 10px; }
				.carousel-arrow.right { right: 10px; }

				.listen-section { padding: 60px 20px; }
				.listen-main-title { font-size: 2.2rem; letter-spacing: 4px; }
				.spotify-grid { grid-template-columns: 1fr; gap: 1.5rem; }

				.project-content-section { padding: 60px 20px; }
				.project-grid-container { grid-template-columns: 1fr; gap: 3rem; text-align: center; }
				.project-left-col { order: 1; }
				.project-right-col { order: 2; align-items: center; }
				.project-header-title { font-size: 2rem; margin-bottom: 1.2rem; }
				.project-description-paragraph { font-size: 1.05rem; line-height: 1.8; margin-bottom: 2rem; }
			}
		</style>
	</head>
	<body>
		<!-- TOP RIGHT BAR SHOWS CORE PORTFOLIO HEADER -->
		<nav class="site-navbar">
			<a href="/" class="navbar-brand">Ray D. Kim</a>
		</nav>

		<!-- FIRST PAGE: MAIN BRANDING HERO BLOCK -->
		<main class="hero-container">
			<div class="logo-wrapper">
				<img src="/iTunesArtwork@2x.png" alt="Superrray Productions Logo" class="site-logo" />
			</div>
			
			<div class="text-overlay">
				<h1 class="site-title">Superrray Productions</h1>
				<div class="social-icons">
					<a href="https://www.imdb.com/name/nm8105113/" target="_blank" class="social-link" aria-label="IMDb"><i class="fa-brands fa-imdb"></i></a>
					<a href="https://www.instagram.com/doraymekim/" target="_blank" class="social-link" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
					<a href="https://music.apple.com/us/artist/ray-d-kim/780192649" target="_blank" class="social-link" aria-label="Apple Music"><i class="fa-brands fa-apple"></i></a>
					<a href="https://open.spotify.com/artist/1JHFQv8E0HG7mmKpuftPLB?trackId=6DDJvEGIgYBg4oO6kdh1AF" target="_blank" class="social-link" aria-label="Spotify"><i class="fa-brands fa-spotify"></i></a>
				</div>
			</div>
		</main>

		<!-- SECOND PAGE: FILM REEL VIDEO -->
		<section class="video-section">
			<div class="video-wrapper" id="videoContainer">
				<div id="videoOverlay" class="video-blur-overlay">
					<img src="/iTunesArtwork@2x.png" alt="Overlay Logo" class="overlay-logo" />
					<i class="fa-solid fa-circle-play play-icon-indicator"></i>
					<h2 class="video-subtitle">Film Reel</h2>
