---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* Import the Paperlogy font family */
			@import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css');
			@font-face {
				font-family: 'Paperlogy';
				src: url('https://fastly.jsdelivr.net/gh/projectnoonnu/2411-3@1.0/Paperlogy-Thin.woff2') format('woff2');
				font-weight: 300;
			}
			@font-face {
				font-family: 'Paperlogy';
				src: url('https://fastly.jsdelivr.net/gh/projectnoonnu/2411-3@1.0/Paperlogy-Medium.woff2') format('woff2');
				font-weight: 500;
			}

			html, body {
				margin: 0;
				padding: 0;
				width: 100%;
				height: 100%;
				overflow: hidden;
				font-family: 'Paperlogy', 'Pretendard', sans-serif;
			}
			.hero-container {
				position: relative;
				width: 100%;
				height: 100vh;
				display: flex;
				justify-content: center;
				align-items: center;
				background-image: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2)), url('/Ray Conduct.JPG');
				background-size: cover;
				background-position: center;
				background-repeat: no-repeat;
			}
			/* The frosted glass container behind your text */
			.text-overlay {
				background: rgba(0, 0, 0, 0.25); /* Subtle dark tint */
				padding: 2rem 4rem;
				border-radius: 12px;
				backdrop-filter: blur(8px); /* This creates the Gaussian blur behind the element */
				-webkit-backdrop-filter: blur(8px); /* Safari support */
				border: 1px solid rgba(255, 255, 255, 0.1); /* Elegant faint border */
				text-align: center;
				max-width: 80%;
			}
			.site-title {
				color: white;
				font-size: 3.5rem;
				font-weight: 300;
				text-transform: uppercase;
				letter-spacing: 6px;
				margin: 0;
				padding: 0;
				text-shadow: 1px 1px 5px rgba(0, 0, 0, 0.3);
			}
			@media (max-width: 768px) {
				.text-overlay {
					padding: 1.5rem 2rem;
				}
				.site-title {
					font-size: 2.2rem;
					letter-spacing: 4px;
				}
			}
		</style>
	</head>
	<body>
		<main class="hero-container">
			<div class="text-overlay">
				<h1 class="site-title">Superrray Productions</h1>
			</div>
		</main>
	</body>
</html>
